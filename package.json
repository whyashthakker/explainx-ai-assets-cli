{
  "name": "@explainx.ai/epx",
  "version": "0.1.2",
  "description": "ExplainX Package Exchange - install AI assets from GitHub",
  "license": "MIT",
  "type": "module",
  "bin": {
    "epx": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "release": "bash scripts/publish.sh"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "dependencies": {
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.5.2",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "commander": "^13.0.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.1.1",
    "semver": "^7.6.3",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.5",
    "@types/semver": "^7.5.8",
    "jest": "^30.2.0",
    "nock": "^14.0.10",
    "ts-jest": "^29.4.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}